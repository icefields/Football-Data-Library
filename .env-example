# Football Data API Configuration
# Get your API key at: https://www.football-data.org/client/register

# Your API key from football-data.org
FOOTBALL_DATA_API_KEY=your_api_key_here

# Path to SQLite database file (will be created if doesn't exist)
DATABASE_PATH=./data/football.db

# API base URL (usually don't change this)
API_BASE_URL=https://api.football-data.org/v4

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Rate limit delay in seconds (free tier: 10 requests/minute, so 6 seconds)
RATE_LIMIT_DELAY=6

